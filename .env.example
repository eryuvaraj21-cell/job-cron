# ============================================
# Job Auto-Apply Bot - Environment Configuration
# ============================================
# Copy this file to .env and fill in your details

# ---------- Your Profile ----------
YOUR_NAME=Your Full Name
YOUR_EMAIL=your.email@example.com
YOUR_PHONE=+91-9999999999

# ---------- Email Notification (Gmail SMTP) ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your.email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFY_EMAIL=your.email@gmail.com

# ---------- LinkedIn Credentials ----------
LINKEDIN_EMAIL=your.linkedin@email.com
LINKEDIN_PASSWORD=your-linkedin-password

# ---------- Naukri Credentials ----------
NAUKRI_EMAIL=your.naukri@email.com
NAUKRI_PASSWORD=your-naukri-password

# ---------- Indeed (No login needed for search) ----------

# ---------- Resume Path ----------
RESUME_PATH=resume/resume.pdf

# ---------- Chrome/Browser ----------
# Set to 'true' to see the browser (useful for debugging)
BROWSER_HEADLESS=true
# Path to Chrome binary (leave empty for auto-detect)
CHROME_BINARY_PATH=

# ---------- Scheduling ----------
CRON_INTERVAL_MINUTES=30

# ---------- Job Search Preferences ----------
JOB_TITLES=Software Engineer,Backend Developer,Full Stack Developer
JOB_LOCATIONS=Bangalore,Remote,Hyderabad
EXPERIENCE_LEVEL=mid
MIN_MATCH_SCORE=60
